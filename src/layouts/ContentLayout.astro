---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Sidebar from '../components/Sidebar.astro';
import LeadForm from '../components/LeadForm.astro';
import { getSidebar } from '../data/sidebars';
import type { NavGroup } from '../data/groups';
import { processContent, addHeadingIds } from '../lib/content';
import { SITE } from '../consts';

interface Crumb { label: string; href?: string; }
interface Props {
  metaTitle: string;
  metaDesc?: string;
  canonical?: string;
  h1: string;
  content: string;
  sidebar?: string;
  breadcrumbs?: Crumb[];
  heroImage?: string;
  heroAlt?: string;
  kind?: 'service' | 'article';
  date?: string;
  modified?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  navGroups?: NavGroup[];
}

const {
  metaTitle, metaDesc, canonical, h1, content,
  sidebar, breadcrumbs = [], heroImage, heroAlt, kind = 'service', date, modified, noindex, jsonLd, navGroups,
} = Astro.props;

const sb = getSidebar(sidebar);
const { html, toc } = addHeadingIds(processContent(content));
const path = Astro.url.pathname;
// Always self-reference the canonical to the page's own URL. The migrated
// `canonical` field was frequently wrong (pointed to a different/broken URL),
// so we ignore it and derive a correct self-canonical from the live path.
const pageUrl = new URL(path, SITE.domain).href;
const ogImg = heroImage ? new URL(heroImage, SITE.domain).href : undefined;

// Auto structured data per page - strong signal for Google & AI engines.
const autoSchema =
  kind === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: h1,
        ...(ogImg ? { image: [ogImg] } : {}),
        ...(date ? { datePublished: new Date(date).toISOString() } : {}),
        ...(modified ? { dateModified: new Date(modified).toISOString() } : {}),
        author: { '@type': 'Organization', name: SITE.name, url: SITE.domain },
        publisher: { '@type': 'Organization', name: SITE.name, logo: { '@type': 'ImageObject', url: `${SITE.domain}/wp-content/uploads/2024/11/קי-פור-מי-לוגו-1.png` } },
        mainEntityOfPage: pageUrl,
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Service',
        name: h1,
        serviceType: h1,
        provider: { '@id': `${SITE.domain}/#business` },
        areaServed: { '@type': 'Country', name: SITE.areaServed },
        url: pageUrl,
      };
const allSchema = [autoSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
const dateLabel = date
  ? new Date(date).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---
<BaseLayout
  title={metaTitle}
  description={metaDesc}
  canonical={pageUrl}
  ogImage={heroImage ? new URL(heroImage, SITE.domain).href : undefined}
  type={kind === 'article' ? 'article' : 'website'}
  noindex={noindex}
  jsonLd={allSchema}
>
  <!-- Page hero band -->
  <section class="page-hero">
    {heroImage && (
      <div class="page-hero__bg"><img src={heroImage} alt={heroAlt ?? h1} width="1600" height="500" loading="eager" /></div>
    )}
    <div class="container page-hero__inner">
      <Breadcrumbs items={[...breadcrumbs.slice(0, -1), { label: h1 }]} />
      <h1>{h1}</h1>
      {dateLabel && kind === 'article' && <p class="page-hero__meta">עודכן: {dateLabel}</p>}
      <div class="page-hero__cta">
        <a href={`tel:${SITE.phoneMobileIntl}`} class="btn btn--primary">חייגו · {SITE.phoneMobile}</a>
        <a href={`https://wa.me/${SITE.whatsapp}`} class="btn btn--ghost" target="_blank" rel="noopener">וואטסאפ</a>
      </div>
    </div>
  </section>

  <!-- Body: content + sidebar -->
  <section class="page-body">
    <div class="container page-grid">
      <article class="page-main">
        {toc.length >= 3 && (
          <details class="toc">
            <summary class="toc__summary">
              <span class="toc__icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              </span>
              <span class="toc__label">תוכן העניינים</span>
              <span class="toc__count">{toc.length} סעיפים</span>
              <svg class="toc__chev" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <nav class="toc__nav" aria-label="תוכן העניינים">
              <ol>
                {toc.map((h) => (
                  <li class={`toc__item toc__item--h${h.level}`}><a href={`#${h.id}`}>{h.text}</a></li>
                ))}
              </ol>
            </nav>
          </details>
        )}
        <div class="prose" set:html={html} />

        <!-- Inline lead CTA at the end of every page -->
        <div class="page-leadcta">
          <div class="page-leadcta__text">
            <h2>קיבלתם את כל המידע? בואו נתקדם</h2>
            <p>צוות קי פור מי זמין עבורכם בכל שעה, בפריסה ארצית. השאירו פרטים ונחזור אליכם מיד.</p>
          </div>
          <LeadForm variant="panel" title="קבלת הצעת מחיר" />
        </div>
      </article>

      <Sidebar sidebar={sb} groups={navGroups} currentPath={path} />
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { position: relative; background: linear-gradient(160deg, var(--navy-800), var(--navy-900)); color: #fff; overflow: hidden; }
  .page-hero__bg { position: absolute; inset: 0; z-index: 0; opacity: 0.28; }
  .page-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero__inner { position: relative; z-index: 1; padding-block: clamp(30px, 5vw, 54px); }
  .page-hero :global(.crumbs a) { color: #aac1da; }
  .page-hero :global(.crumbs a:hover) { color: #fff; }
  .page-hero :global(.crumbs span[aria-current]) { color: #fff; }
  .page-hero :global(.crumbs svg) { color: rgba(255,255,255,0.3); }
  .page-hero h1 { color: #fff; margin-top: 14px; max-width: 880px; }
  .page-hero__meta { color: #aac1da; margin-top: 10px; font-size: 0.92rem; }
  .page-hero__cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 22px; }

  .page-body { padding-block: clamp(40px, 6vw, 70px); background: #fff; }
  .page-grid { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 40px; align-items: start; }
  /* min-width:0 lets the column shrink so wide scrollers (sliders/tables) don't blow out the layout. */
  .page-main { min-width: 0; background: #fff; border: 1px solid var(--line); border-radius: var(--radius-lg); padding: clamp(24px, 4vw, 46px); }

  .page-leadcta { margin-top: 40px; padding-top: 36px; border-top: 1px solid var(--line); display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; }
  .page-leadcta__text h2 { margin-bottom: 12px; }
  .page-leadcta__text p { color: var(--ink-soft); }

  @media (max-width: 960px) {
    /* minmax(0, 1fr) (not bare 1fr) keeps min-width:0 so a wide slider/table can't
       expand the column past the viewport - the cause of the blown-out mobile layout. */
    .page-grid { grid-template-columns: minmax(0, 1fr); gap: 28px; }
    .page-leadcta { grid-template-columns: 1fr; }
  }
</style>
