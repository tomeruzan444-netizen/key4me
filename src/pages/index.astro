---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Faq from '../components/Faq.astro';
import { SITE } from '../consts';

const heroImg = '/wp-content/uploads/2025/05/newkeybannerimg-1.webp';

const trust = [
  { num: '+15', label: 'שנות ניסיון' },
  { num: '24/7', label: 'זמינות מלאה' },
  { num: 'ארצי', label: 'פריסה בכל הארץ' },
  { num: '4.9★', label: 'דירוג לקוחות' },
];

const services = [
  { t: 'פורץ רכבים', d: 'ננעלת מחוץ לרכב? אנחנו מגיעים למיקום המדויק שלך ומחלצים אותך מיידית!', href: '/פורץ-רכבים/', icon: 'car' },
  { t: 'שכפול מפתחות לרכב', d: 'איבדת מפתח לרכב? לא נורא. אנחנו יודעים לשכפל כל מפתח לרכב.', href: '/שכפול-מפתחות-לרכב/', icon: 'key' },
  { t: 'שכפול שלט לרכב', d: 'לא משנה איזה רכב יש לך - אנחנו נוכל לשכפל לו מפתח ושלט.', href: '/קידוד-שלט-לרכב/', icon: 'remote' },
  { t: 'פורץ מנעולים', d: 'המומחיות המרכזית שלנו: לפרוץ כל מנעול, לא משנה כמה הוא מאובטח!', href: '/פורץ-דלתות/', icon: 'lock' },
  { t: 'שחזור מפתחות לרכב', d: 'אם איבדתם את כל המפתחות לרכב - אנחנו נשחזר לכם אותו מאפס!', href: '/שחזור-מפתח-לרכב/', icon: 'keys' },
  { t: 'התקנת מנעול', d: 'התקנת כל סוגי המנעולים, כולל מנעולים חכמים ומנעולי רב בריח.', href: '/מנעול-חכם-לדלת-רב-בריח/', icon: 'shield' },
  { t: 'קידוד שלט לרכב', d: 'קידוד שלטים לכל הרכבים כולל רכבי יוקרה - אנחנו מקודדים כל שלט.', href: '/קידוד-שלט-לרכב/', icon: 'chip' },
  { t: 'תיקון סוויץ׳ לרכב', d: 'תיקון סוויץ׳ לכל סוגי הרכבים, כולל החלפה במקרה הצורך.', href: '/תיקון-סוויץ-לרכב/', icon: 'wrench' },
];

const icons: Record<string, string> = {
  car: '<path d="M5 16.5h14M6 11l1.4-4.2A2 2 0 0 1 9.3 5.4h5.4a2 2 0 0 1 1.9 1.4L18 11m-12 0h12m-12 0a2 2 0 0 0-2 2v3.5h2m12-5.5a2 2 0 0 1 2 2v3.5h-2m-10 0v1.5m8-1.5v1.5M7.5 14h.01M16.5 14h.01" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>',
  key: '<circle cx="8" cy="8" r="3.4" stroke="currentColor" stroke-width="1.7"/><path d="m10.5 10.5 7 7m-2-2 1.6-1.6m-4-3.4 1.4 1.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>',
  keys: '<circle cx="7" cy="9" r="3" stroke="currentColor" stroke-width="1.7"/><circle cx="11" cy="13" r="3" stroke="currentColor" stroke-width="1.7"/><path d="m13 15 5 5m-1.5-3 1.5-1.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>',
  remote: '<rect x="8" y="3" width="8" height="18" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M12 7v3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="14" r="1.4" fill="currentColor"/>',
  lock: '<rect x="5" y="11" width="14" height="9" rx="2.2" stroke="currentColor" stroke-width="1.7"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="15.5" r="1.4" fill="currentColor"/>',
  shield: '<path d="M12 3.5 19 6v5c0 4.4-3 7.8-7 9.5-4-1.7-7-5.1-7-9.5V6l7-2.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>',
  chip: '<rect x="7" y="7" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M10 4v3m4-3v3m-4 10v3m4-3v3M4 10h3m-3 4h3m10-4h3m-3 4h3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>',
  wrench: '<path d="M14.5 4.5a4 4 0 0 1-5 5L4 15v3h3l5.5-5.5a4 4 0 0 0 5-5l-2.2 2.2-1.8-.4-.4-1.8 2.2-2.2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>',
};

const brands = [
  { t: 'מרצדס', href: '/שכפול-מפתח-למרצדס/' },
  { t: 'ב.מ.וו', href: '/שכפול-מפתח-לבמוו/' },
  { t: 'אאודי', href: '/שכפול-מפתח-לרכב-אאודי/' },
  { t: 'סקודה', href: '/שכפול-מפתח-לרכב-סקודה/' },
  { t: 'יונדאי', href: '/שחזור-מפתח-לרכב/שכפול-מפתח-לרכב-יונדאי/' },
  { t: 'קיה', href: '/שחזור-מפתח-לרכב/שכפול-מפתח-לרכב-קיה/' },
  { t: 'טויוטה', href: '/שחזור-מפתח-לרכב/שכפול-מפתח-לרכב-טויוטה/' },
  { t: 'הונדה', href: '/שכפול-מפתח-הונדה/' },
  { t: 'פורד', href: '/שכפול-מפתח-פורד/' },
  { t: 'מאזדה', href: '/שכפול-מפתח-מאזדה/' },
  { t: 'ניסאן', href: '/שכפול-מפתח-ניסאן/' },
  { t: 'רנו', href: '/שכפול-מפתח-רנו/' },
  { t: 'פיג׳ו', href: '/שכפול-מפתח-לרכב-לפיגו/' },
  { t: 'שברולט', href: '/שכפול-מפתח-לשברולט/' },
  { t: 'סוזוקי', href: '/סוזוקי/' },
  { t: 'כל היצרנים', href: '/מחירון-שכפול-מפתח-לרכב-לפי-יצרן/' },
];

const cities = [
  { t: 'תל אביב', href: '/מנעולן-בתל-אביב/' },
  { t: 'חיפה', href: '/מנעולן-בחיפה/' },
  { t: 'יקנעם', href: '/מנעולן-ביקנעם/' },
  { t: 'נהריה', href: '/מנעולן-בנהריה/' },
  { t: 'חולון', href: '/שכפול-מפתח-לרכב-בחולון/' },
  { t: 'קריות', href: '/שכפול-מפתחות-בקריות/' },
  { t: 'פתח תקווה', href: '/שכפול-מפתח-לרכב-בפתח-תקווה/' },
  { t: 'ראשון לציון', href: '/שכפול-מפתחות-לרכב-בראשון-לציון/' },
];

const pricing = [
  ['פריצת רכב', '₪300-450'], ['פריצת בית', '₪300-450'], ['שחזור מפתח לרכב', '₪600-1500'],
  ['שכפול מפתח לרכב', '₪300-600'], ['קידוד שלט לרכב', '₪200-450'], ['תיקון צילינדר', '₪250-450'],
  ['תיקון דלתות', '₪550-1500'],
];

const faqServices = [
  { q: 'ממה צריך להיזהר בעת שכפול מפתחות לרכב?', a: 'הדבר המרכזי ביותר שצריך להיזהר ממנו הוא מלהזמין מנעולן חובבן ללא תעודת מנעולן. עבודות רכב נחשבות מורכבות יותר, ומנעולן ללא ניסיון ותעודה עלול במקרה הגרוע להרוס או לשרוף את מחשב הרכב - מה שעלול לעלות אלפי שקלים. ודאו שלמנעולן שאתם מזמינים יש המלצות ותעודת מנעולן.' },
];
const faq = [
  { q: 'כמה מרוויח מנעולן?', a: 'לרוב, מנעולן מרוויח מעל 9,000 ש״ח בחודש. השכר יכול להשתנות מתקופה לתקופה ותלוי אם המנעולן שכיר או עצמאי.' },
  { q: 'כמה עולה קורס מנעולן?', a: 'המחיר הממוצע עבור קורס מנעולן הוא כ-5,500 ש״ח.' },
  { q: 'כמה עולה מנעולן?', a: 'עבודה של מנעולן מתחילה מ-300 ש״ח בממוצע. העלות תלויה בהמון משתנים כמו סוג העבודה, האם נדרש להחליף חלקים, וזמן העבודה במהלך היום.' },
];

const homeTitle = 'קי פור מי | מנעולן בית ומנעולן רכב בפריסה ארצית - ראו מחירון';
const homeDesc = 'קי פור מי חברה עם מוניטין רב המספקת שירותי מנעולן בית ורכב בפריסה ארצית. אם אתם מחפשים פורץ מנעולים, פורץ רכבים, שחזור מפתחות לרכב או מנעולן רכב 24/7 במחירים הוגנים אנחנו כאן כדי לספק שירות אמין ומקצועי.';
---

<BaseLayout title={homeTitle} description={homeDesc} canonical={`${SITE.domain}/`}>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <img class="hero__bgimg" src={heroImg} alt="צוות קי פור מי - מנעולני רכב ובית בפריסה ארצית" width="1600" height="692" fetchpriority="high" />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__inner">
      <div class="hero__box">
        <span class="hero__badge"><span class="hero__badge-dot"></span> שירות בכל הארץ · זמינים 24/7</span>
        <h1>צריכים מנעולן לרכב או לבית?<br /><span class="hl">השאירו פרטים ונחזור אליכם מיד!</span></h1>
        <LeadForm variant="grid" />
        <p class="hero__altcta">או חייגו עכשיו: <a href={`tel:${SITE.phoneMobileIntl}`}>{SITE.phoneMobile}</a> · <span class="stars">★★★★★</span> מאות לקוחות מרוצים</p>
      </div>
    </div>
  </section>

  <!-- ============ TRUST BAR ============ -->
  <div class="trustbar">
    <div class="container trustbar__inner">
      {trust.map((s) => (<div class="trustbar__item"><strong>{s.num}</strong><span>{s.label}</span></div>))}
    </div>
  </div>

  <!-- ============ SERVICES ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">השירותים שלנו</span>
        <h2>פתרון מקצועי לכל צורך מנעולני</h2>
        <p>מנעולנות רכב ובית תחת קורת גג אחת - צוות מיומן, ציוד חדיש ומענה מהיר בכל שעה.</p>
      </div>
      <div class="cards">
        {services.map((s) => (
          <a href={s.href} class="card reveal">
            <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" set:html={icons[s.icon]} /></span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
            <span class="card__more">לפרטים נוספים<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ BRANDS (navigation booster) ============ -->
  <section class="section section--soft">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">שכפול מפתח לפי יצרן</span>
        <h2>שכפול מפתח לכל יצרני הרכב</h2>
        <p>בחרו את יצרן הרכב שלכם וצפו במחירון ובמידע המלא - מטויוטה ועד מרצדס.</p>
      </div>
      <div class="chips reveal">
        {brands.map((b) => (
          <a href={b.href} class={`chip${b.t === 'כל היצרנים' ? ' chip--accent' : ''}`}>
            <span class="chip__icon"><svg viewBox="0 0 24 24" fill="none" set:html={icons.key} /></span>
            {b.t}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CAR LOCKSMITH SPLIT ============ -->
  <section class="section">
    <div class="container split">
      <div class="split__media reveal">
        <img src="/wp-content/uploads/2024/07/Car-locksmith-.webp" alt="מנעולן רכב של קי פור מי" width="366" height="413" loading="lazy" />
      </div>
      <div class="split__body reveal">
        <span class="eyebrow">מנעולנות רכב</span>
        <h2>מתמחים בכל סוגי העבודות כולל מנעולנות רכב</h2>
        <p>בין ההתמחויות של קי פור מי אפשר למצוא לא מעט עבודות בתחום מנעולנות הרכב. אם אתם צריכים לשחזר מפתח לרכב, לקודד או לשכפל מפתח חדש - זה משהו שאנחנו יכולים לעזור איתו. בנוסף, נוכל להגיע עד אליכם ולבצע את העבודה במקום.</p>
        <div class="quote-card">
          <span class="quote-card__mark">❝</span>
          <p>זה לא המעביד שמשלם לעובד, אלא הצרכן.</p>
          <span class="quote-card__author"><img src="/wp-content/uploads/2024/07/keytestimonial.webp" alt="הנרי פורד" width="44" height="44" loading="lazy" />הנרי פורד</span>
        </div>
        <a href="/שכפול-מפתחות-לרכב/" class="btn btn--navy">לשירותי מנעולן רכב</a>
      </div>
    </div>
  </section>

  <!-- ============ PRICING ============ -->
  <section class="section section--soft">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">שקיפות מלאה</span>
        <h2>מחירון מנעולן</h2>
        <p>טווחי מחירים ממוצעים לשירותים הנפוצים. המחיר הסופי נקבע לפי סוג העבודה והרכב - תמיד בתיאום מראש וללא הפתעות.</p>
      </div>
      <div class="pricing reveal">
        <table>
          <thead><tr><th>סוג עבודה</th><th>טווח מחירים ממוצע</th></tr></thead>
          <tbody>{pricing.map(([k, v]) => (<tr><td>{k}</td><td class="pricing__amount">{v}</td></tr>))}</tbody>
        </table>
        <a href="/מחירון-מנעולן/" class="btn btn--primary btn--lg">למחירון המלא</a>
      </div>
    </div>
  </section>

  <!-- ============ VALUES / DNA ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">ה-DNA שלנו</span>
        <h2>ה-DNA שמרכיב את חברת קי פור מי</h2>
      </div>
      <div class="split reveal">
        <div class="split__media"><img src="/wp-content/uploads/2024/07/Rectangle-36.webp" alt="אמינות כערך מוביל" width="500" height="360" loading="lazy" /></div>
        <div class="split__body">
          <h2>אמינות כערך <span class="hl">מוביל</span></h2>
          <p>אנחנו מבטיחים לספק שירות אמין ומקצועי לכל לקוחותינו ללא יוצא מן הכלל. לא משנה כמה קשה ומסובכת העבודה תהיה - אנחנו נספק מחיר הוגן עבור העבודה. אז אם אתם מחפשים מנעולן אמין וצדיק, אל תהססו להתקשר!</p>
        </div>
      </div>
      <div class="split split--reverse reveal">
        <div class="split__media"><img src="/wp-content/uploads/2024/07/Rectangle-11.webp" alt="מנעולן רכב של קי פור מי" width="500" height="360" loading="lazy" /></div>
        <div class="split__body">
          <h2>מי אנחנו?</h2>
          <p>אנחנו קי פור מי - מנעולן מורשה שעובד בפריסה ארצית. אנחנו עובדים רק עם בעלי המקצוע המקצועיים והאמינים ביותר, כדי לספק לכם הלקוחות את השירות הטוב ביותר שאפשר. מנעולן עם שנים רבות של ניסיון במגוון עבודות רחב - ואנחנו יודעים בדיוק מה אנחנו עושים.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ AREAS (navigation booster) ============ -->
  <section class="section coverage section--soft">
    <div class="container split">
      <div class="split__body reveal">
        <span class="eyebrow">פריסה ארצית</span>
        <h2>צריכים מנעולן לרכב או לבית? נגיע עד אליכם</h2>
        <p>הצוות שלנו פרוס בכל רחבי הארץ ומגיע במהירות לכל מקום - מצפון ועד דרום. בחרו את האזור שלכם:</p>
        <div class="chips chips--cities">
          {cities.map((c) => <a href={c.href} class="chip chip--sm">{c.t}</a>)}
        </div>
        <div class="hero__cta" style="margin-top:24px">
          <a href={`tel:${SITE.phoneMobileIntl}`} class="btn btn--primary">להזמנת מנעולן</a>
        </div>
      </div>
      <div class="split__media reveal"><img src="/wp-content/uploads/2024/07/hand.webp" alt="מפת שירות בפריסה ארצית" width="401" height="389" loading="lazy" /></div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">שאלות ותשובות</span>
        <h2>שאלות נפוצות</h2>
        <p>כל מה שחשוב לדעת לפני שמזמינים מנעולן. לא מצאתם תשובה? אנחנו זמינים בטלפון בכל שעה.</p>
      </div>
      <div class="reveal"><Faq items={[...faqServices, ...faq]} schema={true} /></div>
    </div>
  </section>

  <!-- ============ REVIEWS CTA ============ -->
  <section class="section reviews section--soft">
    <div class="container reviews__inner reveal">
      <div class="reviews__stars stars">★★★★★</div>
      <h2>לקוחות ממליצים על קי פור מי</h2>
      <p>מאות לקוחות מרוצים בכל הארץ. אמינות, מקצועיות ומחירים הוגנים - זה מה שמייחד אותנו.</p>
      <a href="/לקוחות-ממליצים/" class="btn btn--navy btn--lg">לקריאת ההמלצות</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO - team photo as full background, all elements on top */
  .hero { position: relative; color: #fff; overflow: hidden; background: var(--navy-900); display: flex; align-items: center; min-height: clamp(540px, 72vh, 700px); }
  .hero__bgimg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 30% center; z-index: 0; }
  .hero__overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(to left, rgba(13,30,52,0.94) 0%, rgba(13,30,52,0.82) 38%, rgba(13,30,52,0.5) 72%, rgba(13,30,52,0.32) 100%); }
  .hero__inner { position: relative; z-index: 2; width: 100%; padding-block: clamp(40px, 6vw, 72px); }
  .hero__box { max-width: 660px; margin-inline-end: auto; }
  .hero__badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.22); color: #eaf2fb; font-weight: 600; font-size: 0.88rem; padding: 8px 16px; border-radius: 999px; margin-bottom: 20px; }
