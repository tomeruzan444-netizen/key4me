---
import { SITE } from '../consts';
---
<div class="floating">
  <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener" class="floating__btn floating__btn--wa" aria-label="צ׳אט וואטסאפ">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.8 14.1c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.4.7-.4h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.6-.3.3c-.1.1-.3.3-.1.6.1.3.7 1.1 1.4 1.8.9.8 1.7 1.1 2 1.2.2.1.4.1.6-.1l.7-.9c.2-.2.4-.2.6-.1l1.9.9c.3.1.4.2.5.3.1.2.1.7-.1 1.3Z"/></svg>
  </a>
  <a href={`tel:${SITE.phoneMobileIntl}`} class="floating__btn floating__btn--call" aria-label="חיוג מהיר">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.6 15.6 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.3 1l-2.1 2.3Z"/></svg>
  </a>
</div>

<!-- Sticky mobile call bar -->
<a href={`tel:${SITE.phoneMobileIntl}`} class="mobile-callbar">
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.6 15.6 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.3 1l-2.1 2.3Z"/></svg>
  להזמנת מנעולן · {SITE.phoneMobile}
</a>

<style>
  .floating { position: fixed; inset-block-end: 24px; inset-inline-start: 20px; z-index: 90; display: flex; flex-direction: column; gap: 12px; }
  .floating__btn {
    display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: 50%;
    color: #fff; box-shadow: var(--shadow-lg); transition: transform 0.18s; position: relative;
  }
  .floating__btn:hover { transform: scale(1.08); color: #fff; }
  .floating__btn svg { width: 28px; height: 28px; }
  .floating__btn--wa { background: #25d366; }
  .floating__btn--call { background: var(--green-600); animation: ring-pulse 2.4s infinite; }
  @keyframes ring-pulse { 0% { box-shadow: 0 0 0 0 rgba(22,163,74,0.5); } 70% { box-shadow: 0 0 0 14px rgba(22,163,74,0); } 100% { box-shadow: 0 0 0 0 rgba(22,163,74,0); } }

  .mobile-callbar {
    display: none; position: fixed; inset-block-end: 0; inset-inline: 0; z-index: 95;
    align-items: center; justify-content: center; gap: 10px; background: var(--green-600); color: #fff;
    font-family: var(--h-font); font-weight: 700; font-size: 1.05rem; padding: 14px; box-shadow: 0 -4px 18px rgba(0,0,0,0.18);
  }
  .mobile-callbar svg { width: 20px; height: 20px; }

  @media (max-width: 768px) {
    .floating { inset-block-end: 76px; }
    .floating__btn--call { display: none; }
    .mobile-callbar { display: flex; }
  }
</style>
