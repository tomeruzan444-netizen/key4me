---
import { SITE } from '../consts';
import LeadForm from './LeadForm.astro';
import type { Sidebar } from '../data/sidebars';
import type { NavGroup } from '../data/groups';
interface Props { sidebar: Sidebar | null; groups?: NavGroup[]; currentPath?: string; }
const { sidebar, groups, currentPath } = Astro.props;
// Prefer the dynamic, multi-block page-group menus; fall back to the static one.
const blocks: { title: string; items: { label: string; href: string }[] }[] =
  groups && groups.length ? groups : sidebar ? [sidebar] : [];
---
<aside class="sidebar">
  <div class="sidebar__card sidebar__form">
    <div class="sidebar__form-head">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      הזמינו מנעולן רכב
    </div>
    <div class="sidebar__form-body">
      <p class="sidebar__form-lead">השאירו פרטים וקבלו הצעת מחיר במהירות - נחזור אליכם תוך דקות.</p>
      <LeadForm variant="panel" title="" />
    </div>
  </div>

  {blocks.map((blk) => blk.items.length > 0 && (
    <div class="sidebar__card sidebar__menu">
      <h3 class="sidebar__title">{blk.title}</h3>
      <ul>
        {blk.items.map((it) => (
          <li><a href={it.href} class={currentPath === it.href ? 'is-active' : ''}>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {it.label}
          </a></li>
        ))}
      </ul>
    </div>
  ))}

  <div class="sidebar__card sidebar__cta">
    <span class="sidebar__cta-badge">24/7 · שירות חירום</span>
    <h3>צריכים מנעולן עכשיו?</h3>
    <p>מתקשרים ואנחנו בדרך אליכם - בכל מקום ובכל שעה.</p>
    <a href={`tel:${SITE.phoneMobileIntl}`} class="btn btn--primary btn--block">חייגו · {SITE.phoneMobile}</a>
    <a href={`https://wa.me/${SITE.whatsapp}`} class="btn btn--navy btn--block" target="_blank" rel="noopener">שלחו וואטסאפ</a>
  </div>
</aside>

<style>
  .sidebar { display: flex; flex-direction: column; gap: 22px; position: sticky; top: calc(var(--header-h) + 16px); }
  .sidebar__card { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); padding: 22px; }

  /* Lead-form widget (reference-style coloured header) */
  .sidebar__form { padding: 0; overflow: hidden; box-shadow: var(--shadow); border-color: transparent; }
  .sidebar__form-head {
    display: flex; align-items: center; gap: 10px;
    background: linear-gradient(135deg, var(--green-600), var(--green-700));
    color: #fff; font-family: var(--h-font); font-weight: 800; font-size: 1.15rem;
    padding: 16px 20px;
  }
  .sidebar__form-head svg { width: 22px; height: 22px; }
  .sidebar__form-body { padding: 18px 20px 22px; }
  .sidebar__form-lead { color: var(--ink-soft); font-size: 0.92rem; margin-bottom: 14px; }
  .sidebar__form :global(.lead-form__head) { display: none; }
  .sidebar__form :global(.lead-form) { gap: 10px; }
  .sidebar__title { font-size: 1.12rem; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 2px solid var(--green-50); }
  .sidebar__menu ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; max-height: 460px; overflow-y: auto; }
  .sidebar__menu li a { display: flex; align-items: center; gap: 6px; padding: 9px 10px; border-radius: var(--radius-sm); color: var(--ink-soft); font-size: 0.95rem; font-weight: 500; transition: background 0.14s, color 0.14s; }
  .sidebar__menu li a svg { width: 15px; height: 15px; color: var(--green-600); flex-shrink: 0; }
  .sidebar__menu li a:hover, .sidebar__menu li a.is-active { background: var(--green-50); color: var(--green-700); }
  .sidebar__menu li a.is-active { font-weight: 700; }

  .sidebar__cta { background: linear-gradient(160deg, var(--navy-800), var(--navy-900)); color: #fff; text-align: center; }
  .sidebar__cta-badge { display: inline-block; background: var(--green-600); color: #fff; font-weight: 700; font-size: 0.78rem; padding: 5px 13px; border-radius: 999px; margin-bottom: 12px; }
  .sidebar__cta h3 { color: #fff; font-size: 1.25rem; margin-bottom: 8px; }
  .sidebar__cta p { color: #cbd8e8; font-size: 0.95rem; margin-bottom: 16px; }
  .sidebar__cta .btn { margin-top: 8px; }
</style>
