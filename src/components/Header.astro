---
import { SITE, MAIN_NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href?: string) =>
  href && (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="site-header" id="site-header">
  <!-- Utility / top bar -->
  <div class="topbar">
    <div class="container topbar__inner">
      <a href="/" class="brand" aria-label={`${SITE.name} - דף הבית`}>
        <img
          src="/wp-content/uploads/2023/09/cropped-cropped-cropped-KEY4ME-2.png"
          alt={SITE.name}
          width="150" height="54" class="brand__logo" loading="eager" fetchpriority="high"
        />
        <span class="brand__text">
          <strong>{SITE.name}</strong>
          <small>{SITE.tagline}</small>
        </span>
      </a>

      <div class="topbar__actions">
        <span class="topbar__badge">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s-7-6.3-7-11a7 7 0 1 1 14 0c0 4.7-7 11-7 11Z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.8"/></svg>
          שירות בפריסה ארצית · 24/7
        </span>
        <a href={`tel:${SITE.phoneMobileIntl}`} class="topbar__phone">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.6 15.6 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.3 1l-2.1 2.3Z"/></svg>
          <span>{SITE.phoneMobile}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main navigation -->
  <nav class="navbar" aria-label="ניווט ראשי">
    <div class="container navbar__inner">
      <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" id="nav-toggle">
        <span class="nav-toggle__bars" aria-hidden="true"><span></span><span></span><span></span></span>
        <span>תפריט</span>
      </button>

      <ul class="nav">
        {MAIN_NAV.map((item) => (
          <li class={`nav__item${item.children ? ' has-children' : ''}`}>
            {item.children ? (
              <>
                <button class={`nav__link${isActive(item.href) ? ' is-active' : ''}`} aria-haspopup="true" aria-expanded="false">
                  {item.label}
                  <svg class="nav__caret" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="mega">
                  <ul class="mega__list">
                    {item.children.map((c) => (
                      <li><a href={c.href} class={isActive(c.href) ? 'is-active' : ''}>{c.label}</a></li>
                    ))}
                  </ul>
                </div>
              </>
            ) : (
              <a href={item.href} class={`nav__link${isActive(item.href) ? ' is-active' : ''}`}>{item.label}</a>
            )}
          </li>
        ))}
      </ul>

      <a href={`https://wa.me/${SITE.whatsapp}`} class="navbar__wa" target="_blank" rel="noopener" aria-label="וואטסאפ">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.8 14.1c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.4.7-.4h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.6-.3.3c-.1.1-.3.3-.1.6.1.3.7 1.1 1.4 1.8.9.8 1.7 1.1 2 1.2.2.1.4.1.6-.1l.7-.9c.2-.2.4-.2.6-.1l1.9.9c.3.1.4.2.5.3.1.2.1.7-.1 1.3Z"/></svg>
      </a>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div class="mobile-nav" id="mobile-nav" hidden>
    <ul class="mobile-nav__list">
      {MAIN_NAV.map((item) => (
        <li>
          {item.children ? (
            <details>
              <summary>{item.label}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
              <ul>
                {item.href && <li><a href={item.href}><strong>{item.label} - כל השירותים</strong></a></li>}
                {item.children.map((c) => <li><a href={c.href}>{c.label}</a></li>)}
              </ul>
            </details>
          ) : (
            <a href={item.href} class="mobile-nav__top">{item.label}</a>
          )}
        </li>
      ))}
    </ul>
    <div class="mobile-nav__cta">
      <a href={`tel:${SITE.phoneMobileIntl}`} class="btn btn--primary btn--block btn--lg">חייגו עכשיו · {SITE.phoneMobile}</a>
    </div>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 100; background: #fff; }

  /* Top bar */
  .topbar { background: #fff; border-bottom: 1px solid var(--line); }
  .topbar__inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; min-height: 62px; }
  .brand { display: flex; align-items: center; gap: 12px; color: var(--navy-800); }
  .brand__logo { width: auto; height: 46px; }
  .brand__text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand__text strong { font-family: var(--h-font); font-size: 1.18rem; color: var(--navy-800); font-weight: 800; }
  .brand__text small { font-size: 0.74rem; color: var(--muted); }
  .topbar__actions { display: flex; align-items: center; gap: 16px; }
  .topbar__badge { display: inline-flex; align-items: center; gap: 7px; font-size: 0.86rem; font-weight: 600; color: var(--ink-soft); }
  .topbar__badge svg { width: 18px; height: 18px; color: var(--green-600); }
  .topbar__phone {
    display: inline-flex; align-items: center; gap: 9px; background: var(--green-600); color: #fff;
    font-family: var(--h-font); font-weight: 700; font-size: 1.05rem; padding: 10px 20px; border-radius: 999px;
    box-shadow: var(--shadow-green); transition: transform 0.16s, background 0.16s;
  }
  .topbar__phone:hover { background: var(--green-700); color: #fff; transform: translateY(-1px); }
  .topbar__phone svg { width: 18px; height: 18px; }

  /* Navbar */
  .navbar { background: var(--navy-800); color: #fff; box-shadow: var(--shadow-sm); }
  .navbar__inner { display: flex; align-items: center; gap: 12px; }
  .nav { display: flex; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; flex: 1; }
  .nav__item { position: relative; }
  .nav__link {
    display: inline-flex; align-items: center; gap: 5px; color: #eaf0f7; font-family: var(--h-font);
    font-weight: 600; font-size: 0.98rem; padding: 16px 15px; background: none; border: 0; cursor: pointer;
    transition: color 0.15s, background 0.15s; line-height: 1;
  }
  .nav__link:hover, .nav__item:hover .nav__link, .nav__link.is-active { color: #fff; background: rgba(255,255,255,0.08); }
  .nav__link.is-active { box-shadow: inset 0 -3px 0 var(--green-500); }
  .nav__caret { width: 15px; height: 15px; transition: transform 0.2s; }
  .nav__item:hover .nav__caret { transform: rotate(180deg); }

  /* Mega dropdown */
  .mega {
    position: absolute; top: 100%; inset-inline-start: 0; min-width: 280px; background: #fff;
    border-radius: 0 0 var(--radius) var(--radius); box-shadow: var(--shadow-lg);
    padding: 10px; opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: opacity 0.18s var(--ease), transform 0.18s var(--ease), visibility 0.18s; z-index: 50;
    border-top: 3px solid var(--green-600);
  }
  .nav__item.has-children:hover .mega,
  .nav__item.has-children:focus-within .mega { opacity: 1; visibility: visible; transform: none; }
  .mega__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 1px; max-height: 70vh; overflow-y: auto; }
  .mega__list li a {
    display: block; padding: 9px 14px; color: var(--ink-soft); border-radius: var(--radius-sm);
    font-size: 0.96rem; font-weight: 500; transition: background 0.14s, color 0.14s;
  }
  .mega__list li a:hover, .mega__list li a.is-active { background: var(--green-50); color: var(--green-700); }
  /* Wide service menus → 2 columns */
  .nav__item:nth-child(2) .mega, .nav__item:nth-child(3) .mega { min-width: 520px; }
  .nav__item:nth-child(2) .mega__list, .nav__item:nth-child(3) .mega__list { grid-template-columns: 1fr 1fr; gap: 2px 14px; }

  .navbar__wa {
    display: none; align-items: center; justify-content: center; width: 42px; height: 42px;
    background: var(--green-600); color: #fff; border-radius: 50%; flex-shrink: 0;
  }
  .navbar__wa:hover { background: var(--green-700); color: #fff; }
  .navbar__wa svg { width: 22px; height: 22px; }

  /* Mobile toggle */
  .nav-toggle {
    display: none; align-items: center; gap: 9px; background: none; border: 0; color: #fff;
    font-family: var(--h-font); font-weight: 700; font-size: 1rem; padding: 14px 4px;
  }
  .nav-toggle__bars { display: inline-flex; flex-direction: column; gap: 4px; width: 22px; }
  .nav-toggle__bars span { height: 2.5px; background: #fff; border-radius: 2px; transition: transform 0.25s, opacity 0.25s; }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bars span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bars span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bars span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile drawer */
  .mobile-nav { display: none; background: #fff; border-top: 1px solid var(--line); max-height: calc(100vh - var(--header-h)); overflow-y: auto; }
  .mobile-nav__list { list-style: none; margin: 0; padding: 8px 0; }
  .mobile-nav__list > li { border-bottom: 1px solid var(--line); }
  .mobile-nav__top, .mobile-nav summary {
    display: flex; align-items: center; justify-content: space-between; padding: 15px 20px;
    font-family: var(--h-font); font-weight: 700; color: var(--navy-800); font-size: 1.04rem; cursor: pointer; list-style: none;
  }
  .mobile-nav summary::-webkit-details-marker { display: none; }
  .mobile-nav summary svg { width: 20px; height: 20px; transition: transform 0.2s; color: var(--muted); }
  .mobile-nav details[open] summary svg { transform: rotate(180deg); }
  .mobile-nav details ul { list-style: none; margin: 0; padding: 0 0 8px; background: var(--bg-soft); }
  .mobile-nav details ul li a { display: block; padding: 11px 30px; color: var(--ink-soft); font-size: 0.98rem; }
  .mobile-nav details ul li a:hover { color: var(--green-700); }
  .mobile-nav__cta { padding: 16px 20px 22px; }

  @media (max-width: 1100px) {
    .nav { display: none; }
    .nav-toggle { display: inline-flex; }
    .navbar__wa { display: inline-flex; margin-inline-start: auto; }
    .mobile-nav.open { display: block; }
  }
  @media (max-width: 600px) {
    .brand__text small { display: none; }
    .topbar__badge { display: none; }
    .topbar__inner { min-height: 56px; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('mobile-nav');
  if (toggle && drawer) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      drawer.classList.toggle('open', !open);
      drawer.hidden = open;
      document.body.style.overflow = !open ? 'hidden' : '';
    });
  }
</script>
